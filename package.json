{
  "name": "website-watch-cloudflare",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "wrangler types && tsc --noEmit",
    "d1:migrate:local": "wrangler d1 migrations apply website_watch --local",
    "d1:migrate:remote": "wrangler d1 migrations apply website_watch --remote"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.0.2",
    "typescript": "^5.8.3",
    "wrangler": "^4.103.0"
  }
}
